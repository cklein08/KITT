# KITT Environment Variables
# Copy this file to .env and fill in your values
# cp .env.example .env

# ============================================
# INTEGRATIONS
# ============================================

# EasyMCP (Adobe Wiki / Confluence and other hosted MCPs)
# Get your token at https://easymcp.net and enable Adobe Wiki Confluence there
EASYMCP_TOKEN=

# ============================================
# API KEYS
# ============================================

# OpenAI (for TTS / KITT voice when tts-mcp is enabled)
OPENAI_API_KEY=

# ============================================
# VECTOR DB (optional, for semantic search)
# ============================================

# Chroma / other vector DB connection string (if used)
# CHROMA_HOST=
# CHROMA_PORT=

# ============================================
# CUSTOM
# ============================================

# Add your own keys here as needed
# MY_SERVICE_API_KEY=
